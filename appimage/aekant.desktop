[Desktop Entry]
Name=Aekant Browser
Comment=Private, fast, and secure browser
Exec=aekant %u
Icon=aekant
Terminal=false
Type=Application
Categories=Network;WebBrowser;
MimeType=text/html;text/xml;application/xhtml+xml;
StartupNotify=true
Actions=new-window;new-private-window;

[Desktop Action new-window]
Name=New Window
Exec=aekant --new-window

[Desktop Action new-private-window]
Name=New Private Window
Exec=aekant --incognito
